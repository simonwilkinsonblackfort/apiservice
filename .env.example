# MongoDB
MONGODB_URI="mongodb://localhost:27017/blackfort"

# Server
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET="your-signing-key-must-be-at-least-32-characters-long"
JWT_ISSUER="blackfort-dev"
JWT_AUDIENCE="blackfort-dev"
JWT_EXPIRY_MINUTES=4320

# Archista JWT (separate key for Archista integration)
ARCHISTA_JWT_SECRET="your-archista-signing-key-32-chars-minimum"
ARCHISTA_TOKEN_EXPIRY_MINUTES=60

# Refresh / Exchange Token
TOKEN_EXCHANGE_KEY="your-exchange-key"
TOKEN_EXCHANGE_SALT="your-exchange-salt"
REFRESH_KEY="your-refresh-key"

# Secret key for internal service calls (user-signup endpoint)
SECRET_KEY="your-secret-key"

# App config
APP_ID=1
ENV_TAG=dev

# CORS
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001,http://localhost:4321,http://localhost:5173"

# AWS
AWS_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=blackfort-documents
S3_BUCKET_MANUAL_TERMSHEET=blackfort-manual-termsheets

# Redis
REDIS_URL="redis://localhost:6379"

# ChatAI service
CHAT_AI_API_KEY=
CHAT_AI_URL=
CHAT_AI_UTILITY_TYPE=
CHAT_AI_MODEL_ID=
CHAT_AI_ORIGIN=
CHAT_AI_SECRET_KEY=
CHAT_AI_TEMPLATE_NAME=
CHAT_AI_APPLICATION_FEE=
CHAT_AI_PUBLIC_UTILITY_TYPE=
CHAT_AI_PRIVATE_UTILITY_TYPE=
CHAT_AI_COMPARE_OPTION=
CHAT_AI_TERM_SHEET_EXTRACTION=
CHAT_AI_GENERATE_TERM_SHEET=
CHAT_AI_MANUAL_TERM_SHEET_API_KEY=
CHAT_AI_MANUAL_TERM_SHEET_TEMPLATE_NAME=
CHAT_AI_RETRY_COUNT=3

# Webhook
WEBHOOK_URL=

# Admin emails
ADMIN_EMAIL=admin@example.com
ADMIN_EMAIL_SUPPORT_CALLBACK=admin@example.com
ADMIN_EMAIL_SUBSCRIPTION=admin@example.com
ADMIN_EMAIL_CALLBACK_FORM=admin@example.com
TERM_SHEET_CC_EMAIL=admin@example.com

# Application URLs
BLACKFORT_API_URL=http://localhost:3000
BLACKFORT_UI_URL=http://localhost:3000

# ElasticSearch
ELASTICSEARCH_URL=
ELASTICSEARCH_INDEX=
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# SharePoint
SHAREPOINT_TENANT_ID=
SHAREPOINT_CLIENT_ID=
SHAREPOINT_CLIENT_SECRET=
SHAREPOINT_SITE_ID=
SHAREPOINT_FILE_ID=
SHAREPOINT_SHEET_NAME=

# Archistar
ARCHISTAR_URL=
ARCHISTAR_API_KEY=

# CoreLogic
CORELOGIC_URL=
CORELOGIC_ACCOUNT_KEY=
CORELOGIC_ACCOUNT_SECRET=
CORELOGIC_HEADER_TOKEN=

# Equifax
EQUIFAX_URL=
EQUIFAX_ACCOUNT_KEY=
EQUIFAX_ACCOUNT_SECRET=
EQUIFAX_HEADER_TOKEN=

# Security
NONCE_VALIDATION_ENABLED=false
NONCE_VALIDATION_SECRET=your-nonce-secret-key
SHOW_OTP_IN_RESPONSE=true
ENABLE_DATABASE_LOGGING=false
ENABLE_APPLICATION_CHECK=false
